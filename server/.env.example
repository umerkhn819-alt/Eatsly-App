# HTTP port (optional; defaults to 3000)
PORT=3000

# MongoDB connection string (required)
# Example Atlas: mongodb+srv://user:pass@cluster.mongodb.net/?retryWrites=true&w=majority
# Example local: mongodb://127.0.0.1:27017/tasteai
MONGODB_URI=

# Database name used by the API (optional; default tasteai)
MONGODB_DB=tasteai

# Secret for signing JWT access tokens (required). Use a long random string.
# In production, NODE_ENV=production requires at least 32 characters.
JWT_SECRET=

# JWT time-to-live for access tokens (optional; default 7d). jsonwebtoken string format.
JWT_EXPIRES_IN=7d

# development | production | test
NODE_ENV=development

# AI provider selection: auto | spoonacular | gemini | openai (default spoonacular)
AI_PROVIDER=spoonacular

# Spoonacular (primary provider for recipe discovery and assistant)
SPOONACULAR_API_KEY=
# Optional API base URL
SPOONACULAR_BASE_URL=https://api.spoonacular.com
# Request timeout ms (optional; default 60000, max 120000)
SPOONACULAR_TIMEOUT_MS=60000

# Gemini (recommended for this project, optional)
GEMINI_API_KEY=
# Model id (optional; default gemini-2.0-flash)
GEMINI_MODEL=gemini-2.0-flash

# OpenAI (optional fallback)
OPENAI_API_KEY=
# Model id (optional; default gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini
# API base URL (optional; default https://api.openai.com/v1)
OPENAI_BASE_URL=https://api.openai.com/v1
# Request timeout ms (optional; default 60000, max 120000)
OPENAI_TIMEOUT_MS=60000

# OpenRouter (used for snap-photo recipe extraction)
OPENROUTER_API_KEY=
# Base URL for OpenRouter Chat Completions API
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Request timeout ms (optional; default 60000, max 120000)
OPENROUTER_TIMEOUT_MS=60000
# Candidate free Gemma models for auto-selection (comma-separated)
OPENROUTER_GEMMA_MODELS=google/gemma-3n-e4b-it:free,google/gemma-3-27b-it:free,google/gemma-3-12b-it:free
# Additional free vision models if Gemma endpoints are unavailable
OPENROUTER_VISION_FALLBACK_MODELS=meta-llama/llama-3.2-11b-vision-instruct:free,qwen/qwen-2.5-vl-7b-instruct:free,google/gemini-2.0-flash-exp:free

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:8082,http://localhost:5173

# Optional admin bootstrap. When both are set, server ensures this account exists as admin.
ADMIN_BOOTSTRAP_EMAIL=
ADMIN_BOOTSTRAP_PASSWORD=
